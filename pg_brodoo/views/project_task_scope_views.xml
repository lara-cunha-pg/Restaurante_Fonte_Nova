<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_task_form_pg_scope" model="ir.ui.view">
        <field name="name">project.task.form.pg.scope</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="pg_scope" string="Brownfield">
                    <group string="Classificacao Brownfield">
                        <group>
                            <field name="pg_scope_relevant"/>
                            <field name="pg_scope_track"/>
                            <field name="pg_scope_state"/>
                            <field name="pg_scope_kind"/>
                            <field name="pg_scope_sequence"/>
                        </group>
                        <group>
                            <field name="pg_scope_summary"/>
                            <field name="pg_acceptance_criteria_text"/>
                            <field name="pg_out_of_scope_reason" invisible="pg_scope_state != 'excluded'"/>
                        </group>
                    </group>
                    <group
                        string="Requirement Governance"
                        invisible="not pg_scope_relevant or pg_scope_track != 'approved_scope' or pg_scope_kind != 'requirement'"
                    >
                        <group>
                            <field name="pg_requirement_status"/>
                            <field name="pg_requirement_priority"/>
                            <field name="pg_requirement_owner_id"/>
                        </group>
                        <group>
                            <field name="pg_requirement_traceability_refs"/>
                        </group>
                    </group>
                    <group string="Draft Assistido">
                        <group>
                            <field name="pg_scope_enrichment_status" readonly="1"/>
                            <field name="pg_scope_enrichment_confidence" readonly="1" invisible="pg_scope_enrichment_status == 'empty'"/>
                            <field name="pg_scope_enrichment_source" readonly="1" invisible="pg_scope_enrichment_status == 'empty'"/>
                            <field name="pg_scope_enrichment_generated_at" readonly="1" invisible="pg_scope_enrichment_status == 'empty'"/>
                            <field name="pg_scope_enrichment_generated_by_id" readonly="1" invisible="pg_scope_enrichment_status == 'empty'"/>
                        </group>
                        <group>
                            <button
                                name="action_generate_scope_enrichment_draft"
                                type="object"
                                string="Gerar Draft Assistido"
                                class="btn-primary"
                                invisible="not active or not pg_scope_relevant or pg_scope_track != 'approved_scope' or pg_scope_state == 'excluded' or pg_scope_state == 'dropped'"
                            />
                            <button
                                name="action_apply_scope_enrichment_draft"
                                type="object"
                                string="Aplicar Draft Assistido"
                                class="btn-secondary"
                                invisible="pg_scope_enrichment_status == 'empty' or pg_scope_enrichment_status == 'applied' or pg_scope_enrichment_status == 'dismissed'"
                            />
                            <button
                                name="action_discard_scope_enrichment_draft"
                                type="object"
                                string="Descartar Draft Assistido"
                                invisible="pg_scope_enrichment_status == 'empty' or pg_scope_enrichment_status == 'applied' or pg_scope_enrichment_status == 'dismissed'"
                            />
                        </group>
                    </group>
                    <group invisible="pg_scope_enrichment_status == 'empty'">
                        <group>
                            <field name="pg_scope_kind_suggested" readonly="1"/>
                            <field name="pg_scope_summary_suggested" readonly="1"/>
                            <field name="pg_acceptance_criteria_suggested_text" readonly="1"/>
                        </group>
                        <group>
                            <field name="pg_scope_curation_feedback" readonly="1" nolabel="1"/>
                        </group>
                    </group>
                    <group invisible="pg_scope_enrichment_status == 'empty'">
                        <group colspan="2">
                            <field name="pg_scope_enrichment_feedback" readonly="1" nolabel="1"/>
                            <field name="pg_scope_enrichment_signal_feedback" readonly="1" nolabel="1"/>
                            <field name="pg_scope_enrichment_signal_ids" readonly="1" nolabel="1">
                                <list create="0" delete="0" edit="0" open_form_view="1">
                                    <field name="occurred_at"/>
                                    <field name="signal_type"/>
                                    <field name="signal_state"/>
                                    <field name="confidence"/>
                                    <field name="summary"/>
                                </list>
                            </field>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
