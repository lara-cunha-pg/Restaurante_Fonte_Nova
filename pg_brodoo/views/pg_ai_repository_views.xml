<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pg_ai_repository_list" model="ir.ui.view">
        <field name="name">pg.ai.repository.list</field>
        <field name="model">pg.ai.repository</field>
        <field name="arch" type="xml">
            <list string="Repositórios GitHub">
                <field name="full_name"/>
                <field name="default_branch"/>
                <field name="visibility"/>
                <field name="branch_count"/>
                <field name="last_sync_at"/>
            </list>
        </field>
    </record>

    <record id="view_pg_ai_repository_form" model="ir.ui.view">
        <field name="name">pg.ai.repository.form</field>
        <field name="model">pg.ai.repository</field>
        <field name="arch" type="xml">
            <form string="Repositório GitHub">
                <header>
                    <button name="action_sync_branches" type="object" string="Sincronizar Branches" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="full_name" readonly="1"/>
                            <field name="github_owner"/>
                            <field name="github_repo"/>
                        </group>
                        <group>
                            <field name="default_branch"/>
                            <field name="visibility"/>
                            <field name="is_private" readonly="1"/>
                            <field name="last_sync_at" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Branches">
                            <field name="branch_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="is_default"/>
                                    <field name="last_sync_at"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pg_ai_repository" model="ir.actions.act_window">
        <field name="name">Repositorios GitHub</field>
        <field name="res_model">pg.ai.repository</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_project_pg_ai_root"
        name="Brodoo"
        parent="project.menu_main_pm"
        sequence="90"
        groups="project.group_project_user"
    />

    <menuitem
        id="menu_project_config_ai_repository"
        name="Repositorios GitHub"
        parent="menu_project_pg_ai_root"
        action="action_pg_ai_repository"
        sequence="20"
        groups="project.group_project_user"
    />
</odoo>
