<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pg_project_deliveries_sync_run_list" model="ir.ui.view">
        <field name="name">pg.project.deliveries.sync.run.list</field>
        <field name="model">pg.project.deliveries.sync.run</field>
        <field name="arch" type="xml">
            <list string="Runs de Entregáveis">
                <field name="create_date"/>
                <field name="project_id"/>
                <field name="trigger_type"/>
                <field name="status"/>
                <field name="payload_hash"/>
                <field name="finished_at"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_pg_project_deliveries_sync_run_form" model="ir.ui.view">
        <field name="name">pg.project.deliveries.sync.run.form</field>
        <field name="model">pg.project.deliveries.sync.run</field>
        <field name="arch" type="xml">
            <form string="Run de Entregáveis">
                <header>
                    <button
                        name="action_process_now"
                        type="object"
                        string="Processar Agora"
                        class="btn-primary"
                        invisible="status not in ('queued', 'error')"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="project_id"/>
                            <field name="status"/>
                            <field name="trigger_type"/>
                            <field name="trigger_model"/>
                            <field name="trigger_record_id"/>
                            <field name="snapshot_path"/>
                        </group>
                        <group>
                            <field name="payload_hash" readonly="1"/>
                            <field name="published_file_sha" readonly="1"/>
                            <field name="published_commit_sha" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="message" readonly="1"/>
                        <field name="log" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pg_project_deliveries_sync_run" model="ir.actions.act_window">
        <field name="name">PG Deliveries Sync Runs</field>
        <field name="res_model">pg.project.deliveries.sync.run</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_project_config_pg_deliveries_sync_run"
        name="PG Deliveries Sync Runs"
        parent="project.menu_project_config"
        action="action_pg_project_deliveries_sync_run"
        sequence="142"
        groups="project.group_project_user"
    />
</odoo>
